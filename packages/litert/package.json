{
  "name": "@localmode/litert",
  "version": "2.0.0",
  "description": "LiteRT-LM provider for @localmode - Google's on-device LLM inference engine with WebGPU/CPU support, runs .litertlm models (Gemma 4, Qwen3)",
  "license": "MIT",
  "author": "LocalMode",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@litert-lm/core": "^0.12.1"
  },
  "peerDependencies": {
    "@localmode/core": ">=2.0.0"
  },
  "devDependencies": {
    "@localmode/core": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "litert",
    "litert-lm",
    "google",
    "gemma",
    "webgpu",
    "wasm",
    "llm",
    "local-first",
    "privacy",
    "ai",
    "language-model",
    "text-generation",
    "offline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LocalMode-AI/LocalMode.git",
    "directory": "packages/litert"
  },
  "homepage": "https://localmode.dev/docs/litert",
  "bugs": {
    "url": "https://github.com/LocalMode-AI/LocalMode/issues"
  }
}
