{
  "name": "@localmode/react",
  "version": "2.0.0",
  "description": "React hooks for @localmode — useChat, useEmbed, useClassify, and more",
  "license": "MIT",
  "author": "LocalMode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LocalMode-AI/LocalMode.git",
    "directory": "packages/react"
  },
  "homepage": "https://localmode.dev/docs/react",
  "bugs": {
    "url": "https://github.com/LocalMode-AI/LocalMode/issues"
  },
  "keywords": [
    "react",
    "hooks",
    "ai",
    "local-first",
    "privacy",
    "embeddings",
    "llm",
    "chat",
    "classification",
    "offline",
    "browser",
    "transformers"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "@localmode/core": ">=2.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@localmode/core": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
